# Configurações do SAP AI Core / Generative AI Hub
# O resource group "default" deve existir previamente no seu tenant AI Core
AICORE_RESOURCE_GROUP=default

# Nome do modelo Perplexity Sonar no SAP Generative AI Hub
# Valide o nome exato em: AI Launchpad > ML Operations > Models
GENAIHUB_MODEL_NAME=sonar

# Deployment ID (recomendado - evita autodiscovery por nome de modelo)
# Obtenha em: AI Launchpad > ML Operations > Deployments
# Exemplo: d42cc6a9f1d2b9fb
GENAIHUB_DEPLOYMENT_ID=

# Versão do modelo (use "latest" ou valide versão disponível)
GENAIHUB_MODEL_VERSION=latest

# Modelos permitidos (allowlist separada por vírgula)
GENAIHUB_ALLOWED_MODELS=sonar,sonar-pro

# Segurança MCP
# false = sem autenticação (apenas desenvolvimento local)
# true  = exige Bearer Token XSUAA (obrigatório em produção)
MCP_REQUIRE_AUTH=false

# Nível de log: error | warn | info | debug
LOG_LEVEL=info

# Porta local (padrão CAP: 4004)
PORT=4004

# --- SOMENTE PARA DESENVOLVIMENTO LOCAL / MODO HYBRID ---
# Não preencher aqui. Use: cds bind aicore --to default
# As credenciais do AI Core são injetadas automaticamente pelo cds bind.
# Nunca versione service keys ou client secrets.

# Exemplo comentado de como NÃO fazer (não descomente):
# AICORE_CLIENT_ID=...
# AICORE_CLIENT_SECRET=...
# AICORE_AUTH_URL=...
# AICORE_API_URL=...
# PERPLEXITY_API_KEY=...  <-- JAMAIS usar chamada direta à Perplexity
